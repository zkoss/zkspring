<zk xmlns="http://www.zkoss.org/2005/zk/config"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.zkoss.org/2005/zk/config http://www.zkoss.org/2005/zk/config/zk.xsd">
<client-config>
		<debug-js>true</debug-js>
	</client-config>

	<session-config>
	    <session-timeout>1800</session-timeout>
	</session-config>

	<error-page>
		<exception-type>org.springframework.security.access.AccessDeniedException</exception-type>
		<location>/errors/ajaxDenied.zul</location>
	</error-page>
	<client-config>
		<error-reload>
			<device-type>ajax</device-type>
			<error-code>403</error-code>
			<reload-uri>/login.zul</reload-uri>
		</error-reload>
	</client-config>
	<library-property>
		<name>org.zkoss.bind.PhaseListener.class</name>
		<value>org.zkoss.zkspringessentials.bigbank.security.AuthPhaseListener</value>
	</library-property>
</zk>